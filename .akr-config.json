{
  "version": "2.0.0",
  "projectInfo": {
    "name": "training-tracker-ui",
    "description": "Employee training and certification UI",
    "layer": "UI",
    "domains": [
      "Training",
      "CourseCatalog",
      "Enrollment"
    ]
  },
  "documentation": {
    "outputPath": "docs/",
    "componentMappings": {
      "src/components/": "docs/components/",
      "src/pages/": "docs/pages/",
      "src/hooks/": "docs/hooks/",
      "src/context/": "docs/context/",
      "src/services/": "docs/services/",
      "src/utils/": "docs/utils/"
    },
    "templatePreferences": {
      "component": "ui_component_template_module.md",
      "utility": "ui_component_template_module.md"
    },
    "includePatterns": [
      "src/**/*.{ts,tsx}"
    ],
    "excludePatterns": [
      "**/node_modules/**",
      "**/dist/**",
      "**/*.test.*"
    ],
    "autoGenerateOnSave": false,
    "requireReviewBeforeCommit": true
  }
}
